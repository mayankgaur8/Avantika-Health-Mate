{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://api.avantikatechnology.com/api/*"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*"]
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
