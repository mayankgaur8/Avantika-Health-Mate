# ── Frontend (.env) ────────────────────────────────────────────────────────────
# No API keys needed in the frontend — all AI calls go through the backend.

# ── Azure Functions backend (api/local.settings.json) ─────────────────────────
# Copy api/local.settings.json.example → api/local.settings.json and fill in:

# GROQ_API_KEY=gsk_...          # https://console.groq.com/keys
# OPENAI_API_KEY=sk-...         # https://platform.openai.com/api-keys

# Optional overrides:
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# DEFAULT_MODEL_PREFERENCE=cheap   # cheap | premium
# ALLOWED_ORIGIN=https://your-app.azurestaticapps.net
